#include "otool_esp_hosted_fw_update_types.h"
#include <string.h>

/* embedded binary symbols (each entry auto-discovered from firmware dirs) */
@_GEN_EXTERNS@
typedef struct {
    const char *name;      /* logical name, e.g. c6_bluedroid           */
    const char *filename;  /* original filename, e.g. fw_bluedroid.bin  */
    const uint8_t *start;
    const uint8_t *end;
} otool_fw_entry_t_;

static const otool_fw_entry_t_ s_esp_hosted_fw_table[] = {
@_GEN_TABLE_ENTRIES@    /* sentinel — ensures array is never zero-length */
    {nullptr, nullptr, nullptr, nullptr},
};

/* total count excludes the sentinel */
static const size_t s_fw_count =
    sizeof(s_esp_hosted_fw_table) / sizeof(s_esp_hosted_fw_table[0]) - 1U;

esp_err_t OtoolEspHostedFwEmbeddedProvider::get_blob(
    const char *firmware_name, otool_esp_hosted_fw_blob_t &blob)
{
    if (!firmware_name) return ESP_ERR_INVALID_ARG;
    for (size_t i = 0; i < s_fw_count; i++) {
        if (!strcmp(firmware_name, s_esp_hosted_fw_table[i].name) ||
            !strcmp(firmware_name, s_esp_hosted_fw_table[i].filename)) {
            blob.name  = s_esp_hosted_fw_table[i].name;
            blob.start = s_esp_hosted_fw_table[i].start;
            blob.end   = s_esp_hosted_fw_table[i].end;
            return ESP_OK;
        }
    }
    return ESP_ERR_NOT_FOUND;
}

size_t OtoolEspHostedFwEmbeddedProvider::firmware_count() const
{
    return s_fw_count;
}

const char *OtoolEspHostedFwEmbeddedProvider::firmware_name_at(size_t idx) const
{
    if (idx >= s_fw_count) return nullptr;
    return s_esp_hosted_fw_table[idx].name;
}

const char *OtoolEspHostedFwEmbeddedProvider::firmware_original_name_at(size_t idx) const
{
    if (idx >= s_fw_count) return nullptr;
    return s_esp_hosted_fw_table[idx].filename;
}
